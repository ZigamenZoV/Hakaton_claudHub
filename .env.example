# Whisper
WHISPER_MODEL=small            # tiny | base | small | medium | large-v3
WHISPER_DEVICE=cpu             # cpu | cuda
WHISPER_COMPUTE_TYPE=int8      # int8 (cpu) | float16 (gpu) | int8_float16

# Host-exposed ports (inside docker net services still listen on :8000)
WHISPER_HOST_PORT=8100
CHROMA_HOST_PORT=8200

# Ollama (running as `ollama` service inside docker-compose)
# From host:            http://localhost:11434
# From other containers: http://ollama:11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=llama3:8b

# OpenAI — used by Open WebUI as a second provider
# NEVER commit the real key, put it in .env (gitignored)
OPENAI_API_KEY=sk-replace-me

# Open WebUI
WEBUI_AUTH=True               # set False for local single-user dev
OPEN_WEBUI_HOST_PORT=3000
