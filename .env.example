# ===== MWS GPT API (основной провайдер) =====
MWS_API_KEY=sk-ewgiaPC3A6pPDYHwR8siVA
MWS_BASE_URL=https://api.gpt.mws.ru

# Модели MWS (значения по умолчанию уже в коде, переопределяй при необходимости)
MWS_LLM_MODEL=qwen2.5-72b-instruct          # основная текстовая модель
MWS_LLM_FAST_MODEL=mws-gpt-alpha            # быстрая модель для коротких запросов
MWS_LLM_RESEARCH_MODEL=QwQ-32B              # модель для Deep Research
MWS_VLM_MODEL=qwen3-vl-30b-a3b-instruct     # Vision-Language модель
MWS_VLM_FALLBACK_MODEL=cotype-pro-vl-32b    # fallback VLM
MWS_IMAGE_MODEL=qwen-image-lightning         # генерация изображений
MWS_IMAGE_FALLBACK_MODEL=qwen-image          # fallback генерации
MWS_EMBED_MODEL=bge-m3                       # эмбеддинги для RAG
MWS_ASR_MODEL=whisper-medium                 # распознавание речи через MWS
USE_MWS_ASR=true                             # true = ASR через MWS API, false = локальный Whisper

# ===== Open WebUI =====
WEBUI_AUTH=False
WEBUI_NAME=GPTHub

# ===== Whisper (локальный fallback для ASR) =====
WHISPER_MODEL=small                          # tiny|base|small|medium|large-v3
WHISPER_DEVICE=cpu                           # cpu|cuda
WHISPER_COMPUTE_TYPE=int8                    # int8|float16|float32

# ===== ChromaDB (vector store) =====
# Хост и порт задаются в docker-compose, здесь — для локальной разработки
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ===== Qdrant (дополнительный vector store) =====
QDRANT_URL=http://qdrant:6333

# ===== Локальные ML-сервисы (Docker) =====
VLM_URL=http://vlm:8003                     # moondream2 VLM
SD_URL=http://sd_api:8002                    # Stable Diffusion 1.5
WHISPER_URL=http://whisper:8000/transcribe   # локальный Whisper

# ===== RAG =====
RAG_COLLECTION=rag_docs
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=5

# ===== Memory =====
MEM0_COLLECTION=mem0_main
